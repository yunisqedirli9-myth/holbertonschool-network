#!/usr/bin/env bash
# Configures /etc/hosts so localhost resolves to 127.0.0.2 and facebook.com to 8.8.8.8

# Create a safe temporary file
TMP_FILE=$(mktemp)

# Filter out existing localhost and facebook.com entries to avoid duplication
grep -vE 'localhost|facebook\.com' /etc/hosts > "$TMP_FILE"

# Append the new required mappings
echo "127.0.0.2 localhost" >> "$TMP_FILE"
echo "8.8.8.8 facebook.com" >> "$TMP_FILE"

# Overwrite the actual hosts file using sudo
sudo cp "$TMP_FILE" /etc/hosts

# Clean up temp file
rm "$TMP_FILE"
